@page "/"

<PageTitle>kebab.games - Eğlenceli Oyunlar</PageTitle>

<div class="games-container">
    <div class="logo-section">
        <h1 class="logo-title">🥙 kebab.games</h1>
        <p class="logo-subtitle">Lezzetli Oyunlar, Sınırsız Eğlence!</p>
    </div>

    <div class="games-grid">
        <!-- Row 1 -->
        <a href="/snake" class="game-card">
            <div class="game-preview">
                <span class="game-preview-placeholder">🐍</span>
            </div>
            <div class="game-info">
                <h2 class="game-name">Yılan Oyunu</h2>
                <p class="game-description">Klasik yılan oyunu</p>
            </div>
        </a>

        <a href="/tetris" class="game-card">
            <div class="game-preview">
                <span class="game-preview-placeholder">🧱</span>
            </div>
            <div class="game-info">
                <h2 class="game-name">Tetris</h2>
                <p class="game-description">Blokları yerleştir</p>
            </div>
        </a>

        <a href="/mayin-tarlasi" class="game-card">
            <div class="game-preview">
                <span class="game-preview-placeholder">💣</span>
            </div>
            <div class="game-info">
                <h2 class="game-name">Mayın Tarlası</h2>
                <p class="game-description">Mayınları bul</p>
            </div>
        </a>

        <div class="game-card game-card-disabled">
            <div class="game-preview">
                <span class="game-preview-placeholder">🎮</span>
            </div>
