@page "/renk-siralama"

<PageTitle>Renk Sıralama</PageTitle>

<div class="color-sort-game">
    <div class="game-top-bar">
        <a href="./" class="back-button">← Ana Sayfa</a>
        <span class="game-logo">🥙 kebab.games</span>
    </div>
    <h1 class="color-sort-title">Renk Sıralama</h1>

    <div class="color-sort-info">
        <span>Hamle: @moveCount</span>
        <span>Seçili Tüp: @((selectedTubeIndex is null) ? "Yok" : $"{selectedTubeIndex.Value + 1}. tüp")</span>
    </div>

    <div class="color-sort-board-wrapper">
        <div class="color-sort-board"
             tabindex="0"
             aria-label="Renk sıralama tüpleri"
             @onkeydown="HandleKeyDown"
             @onkeydown:preventDefault="true"
             @ref="boardRef">
            @for (var tubeIndex = 0; tubeIndex < tubes.Count; tubeIndex++)
            {
                <button type="button"
                        class="color-sort-tube @(selectedTubeIndex == tubeIndex ? "is-selected" : string.Empty) @(focusedTubeIndex == tubeIndex ? "is-focused" : string.Empty)"
                        @onclick="() => HandleTubeClick(tubeIndex)"
                        disabled="@(isWin)">
                    @for (var segmentIndex = TubeCapacity - 1; segmentIndex >= 0; segmentIndex--)
                    {
                        var color = segmentIndex < tubes[tubeIndex].Count ? tubes[tubeIndex][segmentIndex] : null;
                        <div class="color-sort-segment @(color is null ? "is-empty" : string.Empty)"
                             style="background-color: @(color ?? "transparent")"></div>
                    }
                </button>
            }
        </div>

        @if (isWin)
        {
            <div class="color-sort-overlay">
                <div class="color-sort-overlay-content">
                    <h2>Tebrikler!</h2>
                    <p>Renkleri başarıyla ayırdın.</p>
                    <button class="btn btn-primary" @onclick="StartNewGame">Yeni Oyun</button>
                </div>
            </div>
        }
    </div>

    <div class="color-sort-controls">
        <button class="btn btn-outline-primary" @onclick="StartNewGame">Yeniden Karıştır</button>
        <p><strong>Nasıl oynanır:</strong></p>
        <p>Tüpe tıklayıp aynı renkteki sıvıyı boş ya da aynı renkteki tüpe dök.</p>
        <p><strong>Kontroller:</strong></p>
        <p>Ok Tuşları - Tüp değiştir</p>
        <p>Enter / Boşluk - Tüp seç veya dök</p>
        <p>Esc - Seçimi iptal et</p>
    </div>
</div>

@code {
    private const int TubeCapacity = 4;
    private static readonly string Red = "#ff6b6b";
    private static readonly string Blue = "#4facfe";
    private static readonly string Green = "#43e97b";
    private static readonly string Yellow = "#feca57";

    private const int EmptyTubeCount = 2;
    private static readonly string[] Colors = { Red, Blue, Green, Yellow };

    private readonly Random random = new();
    private List<List<string>> tubes = new();
    private int? selectedTubeIndex;
    private int moveCount;
    private bool isWin;
    private int focusedTubeIndex;
    private ElementReference boardRef;
    private bool shouldFocusBoard = true;

    protected override void OnInitialized()
    {
        StartNewGame();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (shouldFocusBoard)
        {
            shouldFocusBoard = false;
            await boardRef.FocusAsync();
        }
    }

    private void StartNewGame()
    {
        var colorPool = new List<string>(Colors.Length * TubeCapacity);
        foreach (var color in Colors)
        {
            for (var i = 0; i < TubeCapacity; i++)
            {
                colorPool.Add(color);
            }
        }

        Shuffle(colorPool);

        tubes = new List<List<string>>();
        var colorIndex = 0;
        for (var i = 0; i < Colors.Length; i++)
        {
            var tube = new List<string>();
            for (var segment = 0; segment < TubeCapacity; segment++)
            {
                tube.Add(colorPool[colorIndex++]);
            }
            tubes.Add(tube);
        }

        for (var i = 0; i < EmptyTubeCount; i++)
        {
            tubes.Add(new List<string>());
        }

        selectedTubeIndex = null;
        moveCount = 0;
        isWin = false;
        focusedTubeIndex = 0;
        shouldFocusBoard = true;
    }

    private void HandleTubeClick(int tubeIndex)
    {
        if (isWin)
        {
            return;
        }

        focusedTubeIndex = tubeIndex;
        if (selectedTubeIndex is null)
        {
            selectedTubeIndex = tubeIndex;
            return;
        }

        if (selectedTubeIndex == tubeIndex)
        {
            selectedTubeIndex = null;
            return;
        }

        var sourceIndex = selectedTubeIndex.Value;
        var targetIndex = tubeIndex;
        if (tubes[sourceIndex].Count == 0 && tubes[targetIndex].Count > 0)
        {
            (sourceIndex, targetIndex) = (targetIndex, sourceIndex);
        }

        if (TryPour(sourceIndex, targetIndex))
        {
            moveCount++;
            if (CheckForWin())
            {
                isWin = true;
            }
        }

        selectedTubeIndex = null;
    }

    private void HandleKeyDown(KeyboardEventArgs args)
    {
        if (isWin)
        {
            return;
        }

        if (tubes.Count == 0)
        {
            return;
        }

        switch (args.Key)
        {
            case "ArrowLeft":
            case "a":
            case "A":
                MoveFocus(-1);
                break;
            case "ArrowRight":
            case "d":
            case "D":
                MoveFocus(1);
                break;
            case "ArrowUp":
            case "w":
            case "W":
                MoveFocus(-1);
                break;
            case "ArrowDown":
            case "s":
            case "S":
                MoveFocus(1);
                break;
            case "Enter":
            case " ":
                HandleTubeClick(focusedTubeIndex);
                break;
            case "Escape":
                selectedTubeIndex = null;
                break;
        }
    }

    private void MoveFocus(int delta)
    {
        var count = tubes.Count;
        if (count == 0)
        {
            return;
        }

        focusedTubeIndex = (focusedTubeIndex + delta + count) % count;
    }

    private void Shuffle<T>(IList<T> items)
    {
        for (var i = items.Count - 1; i > 0; i--)
        {
            var swapIndex = random.Next(i + 1);
            (items[i], items[swapIndex]) = (items[swapIndex], items[i]);
        }
    }

    private bool TryPour(int sourceIndex, int targetIndex)
    {
        var source = tubes[sourceIndex];
        var target = tubes[targetIndex];

        if (source.Count == 0 || target.Count == TubeCapacity)
        {
            return false;
        }

        var color = source[^1];
        if (target.Count > 0 && target[^1] != color)
        {
            return false;
        }

        var availableSpace = TubeCapacity - target.Count;
        var sameColorCount = 0;
        for (var i = source.Count - 1; i >= 0; i--)
        {
            if (source[i] != color)
            {
                break;
            }

            sameColorCount++;
        }

        var pourCount = Math.Min(availableSpace, sameColorCount);
        var startIndex = source.Count - pourCount;
        var moving = source.GetRange(startIndex, pourCount);
        source.RemoveRange(startIndex, pourCount);
        target.AddRange(moving);
        return true;
    }

    private bool CheckForWin()
    {
        foreach (var tube in tubes)
        {
            if (tube.Count == 0)
            {
                continue;
            }

            if (tube.Count != TubeCapacity)
            {
                return false;
            }

            var color = tube[0];
            for (var i = 1; i < tube.Count; i++)
            {
                if (tube[i] != color)
                {
                    return false;
                }
            }
        }

        return true;
    }
}
